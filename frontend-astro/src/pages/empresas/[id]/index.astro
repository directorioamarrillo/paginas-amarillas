---
import GlobalLayout from "../../../layout/GlobalLayout.astro";
import { axiosInstance } from "../../../utils/axiosInstance";
import { EnviarCalificacion } from "../../../components/Formularios/EnviarCalificacion";
import dayjs from "dayjs";
import { BotonEliminarEmpresa } from "../../../components/commons/BotonEliminarEmpresa";
import MapEmpresa from "../../../components/commons/MapEmpresa";
import { Mail, Phone, MapPin, Tag, Store, Map as MapIcon, ExternalLink, Star, Calendar, MessageCircle, Edit2 } from 'lucide-react';
const { id } = Astro.params;

const id_usuario = (Astro.cookies.get("id_usuario") || {})?.value;
const rol = (Astro.cookies.get("rol") || {})?.value;
const token = (Astro.cookies.get("token") || {})?.value;

let empresa = null;
let reviews = [];
let error = null;
let promedio = null;

import fs from 'fs/promises';
import path from 'path';

// Empresa detail
try {
  const { data } = await axiosInstance.get(`/api/empresas/${id}`);
  empresa = data;
} catch (err: any) {
      const msg = (err && (err.message || (err as any).toString())) || 'Error al conectar con el backend.';
      console.warn('Error al cargar empresa desde API:', msg);
  try {
    const mockPath = path.join(process.cwd(), 'public', 'mock', 'empresas.json');
    const content = await fs.readFile(mockPath, 'utf-8');
    const all = JSON.parse(content);
    empresa = all.find((it: any) => String(it.id_empresa) === String(id)) || null;
    if (!empresa) {
      error = 'Empresa no encontrada (mock)';
    }
    console.log('Usando mock empresa:', mockPath);
  } catch (me) {
    console.error('No se pudo cargar mock de empresa:', me);
    error = err.message || 'Error al cargar empresa';
  }
}

// Reviews
try {
  const { data: dataReview } = await axiosInstance.get(`/api/reviews/${id}`);
  reviews = dataReview;
} catch (err: any) {
      const msg = (err && ((err as any).message || err.toString())) || 'Error al conectar con el backend.';
      console.warn('Error al cargar reviews desde API:', msg);
  // fallback: intentar cargar mock reviews por empresa
  try {
    const mockPath = path.join(process.cwd(), 'public', 'mock', `reviews_${id}.json`);
    const content = await fs.readFile(mockPath, 'utf-8');
    reviews = JSON.parse(content);
    console.log('Usando mock reviews:', mockPath);
  } catch (me: any) {
    console.warn('No hay mock de reviews para esta empresa, se usa lista vacía', me);
    reviews = [];
  }
}

if (reviews.length > 0) {
  const sum = reviews.reduce((acc: number, r: any) => acc + (r.calificacion || 0), 0);
  promedio = (sum / reviews.length).toFixed(1);
}

let puedeComentar = false;

if (
  !!id_usuario &&
  !reviews.find((review: any) => review.id_usuario.toString() === id_usuario)
)
  puedeComentar = true;
---

<GlobalLayout title={empresa?.nombre || "Empresa"}>
  {error ? (
    <div class="max-w-4xl mx-auto py-12 px-6">
      <div class="bg-red-50 border border-red-200 rounded-lg p-6 text-center">
        <p class="text-red-600 text-lg">Error: {error}</p>
        <a href="/" class="inline-block mt-4 text-blue-600 hover:underline">Volver al inicio</a>
      </div>
    </div>
  ) : empresa ? (
    <div class="max-w-6xl mx-auto py-12 px-6">
      <!-- Botones de admin -->
      {rol === "admin" && (
        <div class="flex justify-end gap-3 mb-6">
          <a
            href={`/admin/empresas/editar/${id}`}
            class="px-6 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors"
          >
            <Edit2 class="icon-sm" /> Editar
          </a>
          <BotonEliminarEmpresa id={id || ""} client:load />
        </div>
      )}

      <!-- Hero de empresa -->
      <div class="bg-gradient-to-br from-amarillo-claro to-amarillo-medio rounded-2xl shadow-xl overflow-hidden mb-8">
        <div class="grid md:grid-cols-2 gap-8 p-8">
          <!-- Imagen -->
          <div class="flex items-center justify-center">
            {empresa.logo ? (
              <img
                src={empresa.logo}
                alt={empresa.nombre}
                class="w-full max-w-md h-80 object-cover rounded-xl shadow-lg"
              />
            ) : (
              <div class="w-full max-w-md h-80 bg-gray-200 rounded-xl flex items-center justify-center">
                <Store size={72} class="text-gray-400" />
              </div>
            )}
          </div>

          <!-- Información principal -->
          <div class="flex flex-col justify-center">
            <h1 class="text-4xl font-bold text-gray-900 mb-2 flex items-center gap-3">
              {empresa.nombre}
              {promedio && (
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-yellow-200 text-yellow-900 text-sm font-semibold">
                  <Star class="icon-sm" /> {promedio}
                </span>
              )}
            </h1>
            {promedio && (
              <p class="text-sm text-gray-500 mb-4">Promedio de {reviews.length} reseña(s)</p>
            )}
            
            <div class="space-y-3">
              <div class="flex items-start gap-3">
                <Tag class="icon-md text-gray-600" />
                <div>
                  <p class="text-sm text-gray-500 font-medium">NIT</p>
                  <p class="text-lg text-gray-800">{empresa.nit}</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Mail class="icon-md text-gray-600" />
                <div>
                  <p class="text-sm text-gray-500 font-medium">Correo</p>
                  <a href={`mailto:${empresa.correo}`} class="text-lg text-blue-600 hover:underline">
                    {empresa.correo}
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Phone class="icon-md text-gray-600" />
                <div>
                  <p class="text-sm text-gray-500 font-medium">Teléfono</p>
                  <a href={`tel:${empresa.telefono}`} class="text-lg text-blue-600 hover:underline">
                    {empresa.telefono}
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <MapPin class="icon-md text-gray-600" />
                <div>
                  <p class="text-sm text-gray-500 font-medium">Dirección</p>
                  <p class="text-lg text-gray-800">{empresa.direccion}</p>
                </div>
              </div>

              <div class="flex gap-3 mt-4">
                {empresa.categoria && (
                  <a href={`/marketplace?categoria=${empresa.id_categoria}`} class="inline-flex items-center px-4 py-2 bg-yellow-100 hover:bg-yellow-200 text-yellow-800 rounded-full text-sm font-medium transition">
                    <Tag class="icon-sm" /> {empresa.categoria.nombre}
                  </a>
                )}
                {empresa.municipio && (
                  <a href={`/marketplace?municipio=${empresa.id_municipio}`} class="inline-flex items-center px-4 py-2 bg-blue-100 hover:bg-blue-200 text-blue-800 rounded-full text-sm font-medium transition">
                    <MapPin class="icon-sm" /> {empresa.municipio.nombre}
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mapa de geolocalización -->
      <div class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center gap-2"><MapIcon class="icon-md" /> Ubicación</h2>
        <MapEmpresa
          direccion={empresa.direccion}
          municipio={empresa.municipio?.nombre}
          nombre={empresa.nombre}
          client:only="react"
        />
        <p class="text-xs text-gray-400 mt-2">Fuente: OpenStreetMap / Nominatim</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(empresa.direccion + ' ' + (empresa.municipio?.nombre || '') + ' Colombia')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-green-600 text-white text-sm font-semibold hover:bg-green-700 transition"
          >
            <MapPin class="icon-sm" /> Ver en Google Maps <ExternalLink class="icon-sm" />
          </a>
        </div>
      </div>

      <!-- Sección de reseñas -->
      <div class="bg-white rounded-2xl shadow-lg p-8 mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-6 flex items-center gap-3">
          <Star class="icon-md text-yellow-500" /> Calificaciones y Reseñas
        </h2>

        {reviews.length > 0 ? (
          <div class="grid md:grid-cols-2 gap-6">
            {reviews.map((review: any) => (
              <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-6 border border-gray-200">
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-bold text-lg text-gray-900">
                    {review.id_usuario.toString() === id_usuario ? "Tú" : review.usuario.nombre}
                  </h3>
                  <div class="flex items-center gap-1">
                    {[...Array(5)].map((_, i) => (
                      <Star size={16} class={i < review.calificacion ? "text-yellow-400" : "text-gray-300"} />
                    ))}
                    <span class="ml-2 text-sm font-semibold text-gray-700">
                      {review.calificacion}/5
                    </span>
                  </div>
                </div>
                
                <p class="text-sm text-gray-500 mb-3 flex items-center gap-2">
                  <Calendar class="icon-sm text-gray-500" /> {dayjs(review.fecha).subtract(5, "hours").format("DD/MM/YYYY HH:mm")}
                </p>
                
                <p class="text-gray-700 leading-relaxed">
                  {review.comentario}
                </p>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-12 bg-gray-50 rounded-xl">
            <MessageCircle size={56} class="text-gray-300 block mb-4 mx-auto" />
            <p class="text-gray-500 text-lg">Aún no hay calificaciones para esta empresa</p>
            <p class="text-gray-400 text-sm mt-2">¡Sé el primero en dejar una reseña!</p>
          </div>
        )}
      </div>

      <!-- Formulario de calificación -->
      {puedeComentar && (
        <div class="bg-gradient-to-br from-yellow-50 to-orange-50 rounded-2xl shadow-lg p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
            <Edit2 class="icon-md" /> Deja tu calificación
          </h2>
          <EnviarCalificacion
            id_usuario={id_usuario}
            id_empresa={id}
            client:load
          />
        </div>
      )}

      {!token && (
        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-8 text-center">
          <span class="text-5xl block mb-4">🔐</span>
          <p class="text-gray-700 text-lg mb-6">
            Inicia sesión para dejar una calificación y compartir tu experiencia
          </p>
          <a
            href="/iniciar-sesion"
            class="inline-block px-8 py-3 bg-yellow-500 text-white font-semibold rounded-lg hover:bg-yellow-600 transition-colors shadow-md"
          >
            Iniciar Sesión
          </a>
        </div>
      )}
    </div>
  ) : null}
</GlobalLayout>
